---
import styles from '@/styles/Footer.module.css';

const currentYear = new Date().getFullYear();
---

<footer class={styles.footer}>
  <!-- CTA Section -->
  <section class={styles.cta}>
    <div class="container">
      <div class={`${styles.ctaContent} reveal`}>
        <p class={styles.ctaLabel}>Got a project?</p>
        <a href="mailto:hanmin84200@gmail.com" class={styles.ctaTitle}>
          Let's talk
          <span class={styles.ctaArrow}>&rarr;</span>
        </a>
        <p class={styles.ctaEmail}>hanmin84200@gmail.com</p>
      </div>
    </div>
  </section>

  <!-- Bottom Bar -->
  <div class={styles.bottom}>
    <div class="container">
      <div class={styles.bottomContent}>
        <p class={styles.copyright}>&copy; {currentYear} Minkyu Han</p>
        <div class={styles.socials}>
          <a href="https://github.com/oats7777" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/fe-minkyu" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            LinkedIn
          </a>
          <a href="/rss.xml" aria-label="RSS">
            RSS
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
