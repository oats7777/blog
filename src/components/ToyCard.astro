---
import styles from '@/styles/ToyCard.module.css';

export interface Props {
  title: string;
  description: string;
  slug: string;
  date: string;
  techStack: string;
  tags: string[];
  featured?: boolean;
}

const { title, description, slug, techStack, tags, featured = false } = Astro.props;
---

<article class={`${styles.card} ${featured ? styles.featured : ''}`}>
  <a href={`/toys/${slug}`} class={styles.cardLink}>
    <div class={styles.cardContent}>
      <div class={styles.badges}>
        <span class={styles.techBadge}>{techStack}</span>
      </div>
      <h3 class={styles.title}>{title}</h3>
      <p class={styles.description}>{description}</p>
      {tags && tags.length > 0 && (
        <div class={styles.tags}>
          {tags.map((tag) => (
            <span class={styles.tag}>{tag}</span>
          ))}
        </div>
      )}
    </div>
    <div class={styles.overlay}>
      <span class={styles.overlayText}>Try it &rarr;</span>
    </div>
  </a>
</article>
