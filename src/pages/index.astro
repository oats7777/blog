---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Marquee from '@/components/Marquee.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import styles from '@/styles/Home.module.css';

type PostEntry = CollectionEntry<'posts'>;
type ToyEntry = CollectionEntry<'toys'>;

// Get recent posts
const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .filter((post: PostEntry) => !post.data.draft)
  .sort((a: PostEntry, b: PostEntry) => {
    const dateDiff = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    if (dateDiff !== 0) return dateDiff;
    return (a.data.order ?? 0) - (b.data.order ?? 0);
  })
  .slice(0, 3);

// Get toys for Selected Works
const allToys = await getCollection('toys');
const toys = allToys
  .filter((toy: ToyEntry) => !toy.data.draft)
  .sort((a: ToyEntry, b: ToyEntry) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit' }).replace('/', '.');
};
---

<Layout title="Minkyu Han - Frontend Developer & Creative Engineer">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class={styles.hero}>
      <div class={`container ${styles.heroContainer}`}>
        <p class="section-label">Frontend Developer & Creative Engineer</p>
        <h1 class={styles.heroTitle}>
          <span class={`${styles.heroLine} reveal`}>I craft digital</span>
          <span class={`${styles.heroLine} reveal`} data-delay="0.1">experiences with</span>
          <span class={`${styles.heroLine} reveal`} data-delay="0.2">code & <span class={styles.accent}>creativity</span></span>
        </h1>
        <div class={styles.scrollHint}>
          <span class={styles.scrollArrow}>&darr;</span>
        </div>
      </div>
    </section>

    <!-- Selected Works -->
    {toys.length > 0 && (
      <section class={styles.works}>
        <div class="container">
          <p class="section-label reveal">Selected Works</p>
          <div class={styles.worksList}>
            {toys.map((toy: ToyEntry, i: number) => (
              <a
                href={`/toys/${toy.slug}`}
                class={`${styles.workItem} reveal`}
                data-delay={String(i * 0.1)}
              >
                <span class={styles.workNumber}>
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class={styles.workInfo}>
                  <h3 class={styles.workTitle}>{toy.data.title}</h3>
                  <p class={styles.workDesc}>{toy.data.description}</p>
                </div>
                <div class={styles.workTags}>
                  {toy.data.tags.slice(0, 3).map((tag: string) => (
                    <span class={styles.workTag}>{tag}</span>
                  ))}
                </div>
                <span class={styles.workArrow}>&rarr;</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Latest Posts -->
    <section class={styles.posts}>
      <div class="container">
        <p class="section-label reveal">Latest Writings</p>
        <div class={styles.postsList}>
          {recentPosts.map((post: PostEntry, i: number) => (
            <a
              href={`/posts/${post.slug}`}
              class={`${styles.postItem} reveal`}
              data-delay={String(i * 0.08)}
            >
              <span class={styles.postDate}>{formatDate(post.data.date)}</span>
              {post.data.category && (
                <span class={styles.postCategory}>{post.data.category}</span>
              )}
              <span class={styles.postTitle}>{post.data.title}</span>
              <span class={styles.postArrow}>&rarr;</span>
            </a>
          ))}
        </div>
        <div class={`${styles.viewAll} reveal`} data-delay="0.3">
          <a href="/posts">View all posts &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <Marquee />
  </main>

  <Footer />
</Layout>
