---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import styles from '@/styles/PostsList.module.css';

type PostEntry = CollectionEntry<'posts'>;

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const publishedPosts = allPosts.filter((post: PostEntry) => !post.data.draft);

  const categories = [
    ...new Set(publishedPosts.map((post: PostEntry) => post.data.category).filter(Boolean)),
  ] as string[];

  return categories.map((category: string) => ({
    params: { category: category.toLowerCase() },
    props: { category },
  }));
}

const { category } = Astro.props as { category: string };

const allPosts = await getCollection('posts');

const allPublished = allPosts
  .filter((post: PostEntry) => !post.data.draft)
  .sort((a: PostEntry, b: PostEntry) => {
    const dateDiff = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    if (dateDiff !== 0) return dateDiff;
    return (a.data.order ?? 0) - (b.data.order ?? 0);
  });

const posts = allPublished.filter((post: PostEntry) => post.data.category === category);

const categoryCount = allPublished.reduce((acc: Record<string, number>, post: PostEntry) => {
  if (post.data.category) {
    acc[post.data.category] = (acc[post.data.category] || 0) + 1;
  }
  return acc;
}, {});

const categories = Object.keys(categoryCount).sort();

const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit' }).replace('/', '.');
};
---

<Layout title={`${category} - Blog - Minkyu Han`} description={`${category} 카테고리의 글 목록입니다.`}>
  <Header />

  <main class={styles.main}>
    <div class="container">
      <!-- Hero -->
      <section class={styles.hero}>
        <p class="section-label reveal">Blog</p>
        <h1 class={`${styles.title} reveal`} data-delay="0.1">Writings & Thoughts</h1>
        <p class={`${styles.desc} reveal`} data-delay="0.2">
          프론트엔드 개발, 아키텍처, 그리고 창작에 대한 기록
        </p>
      </section>

      <!-- Category Filter -->
      <div class={`${styles.filters} reveal`} data-delay="0.3">
        <a href="/posts" class={styles.filterPill}>
          All ({allPublished.length})
        </a>
        {categories.map((cat: string) => (
          <a
            href={`/posts/category/${cat.toLowerCase()}`}
            class={`${styles.filterPill} ${cat === category ? styles.active : ''}`}
          >
            {cat} ({categoryCount[cat]})
          </a>
        ))}
      </div>

      <!-- Post List -->
      <div class={styles.list}>
        {posts.map((post: PostEntry, i: number) => (
          <a
            href={`/posts/${post.slug}`}
            class={`${styles.item} reveal`}
            data-delay={String(Math.min(i * 0.05, 0.5))}
          >
            <span class={styles.date}>{formatDate(post.data.date)}</span>
            {post.data.category && (
              <span class={styles.category}>{post.data.category}</span>
            )}
            <div class={styles.itemContent}>
              <span class={styles.itemTitle}>{post.data.title}</span>
              <span class={styles.itemDesc}>{post.data.description}</span>
            </div>
            <span class={styles.arrow}>&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
