---
import { getCollection, type CollectionEntry } from 'astro:content';
import styles from '@/styles/ToyDetail.module.css';
import Footer from '@/components/Footer.astro';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';

import RustCanvas from '@/components/toys/RustCanvas.astro';

type ToyEntry = CollectionEntry<'toys'>;

const toyComponents: Record<string, any> = {
  'rust-canvas': RustCanvas,
};

export async function getStaticPaths() {
  const toys = await getCollection('toys');
  return toys.map((toy: ToyEntry) => ({
    params: { slug: toy.slug },
    props: { toy },
  }));
}

const { toy } = Astro.props as { toy: ToyEntry };
const { Content } = await toy.render();

const ToyComponent = toyComponents[toy.slug];
const isIsland = !!ToyComponent;
---

<Layout
  title={`${toy.data.title} - Minkyu Han`}
  description={toy.data.description}
  article={true}
  publishedTime={toy.data.date}
  tags={toy.data.tags || []}
>
  <Header />

  <main class={styles.main}>
    <div class="container">
      <a href="/toys" class={`${styles.backLink} reveal`}>&larr; Back to Playground</a>

      <!-- Info Card -->
      <div class={`${styles.infoCard} reveal`} data-delay="0.1">
        <div class={styles.infoTags}>
          <span class={styles.techBadge}>{toy.data.techStack}</span>
          {toy.data.tags.map((tag: string) => (
            <span class={styles.tag}>#{tag}</span>
          ))}
        </div>
        <h1 class={styles.title}>{toy.data.title}</h1>
        <p class={styles.desc}>{toy.data.description}</p>
      </div>

      <!-- Embed Area -->
      <div class={`${styles.embedWrapper} reveal`} data-delay="0.2">
        <div class={styles.embedBar}>
          <div class={styles.dots}>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <span class={styles.embedTitle}>{toy.data.title}</span>
        </div>
        <div class={styles.embedContent}>
          {isIsland ? (
            <ToyComponent />
          ) : (
            <iframe
              src={toy.data.embedUrl}
              title={toy.data.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class={styles.iframe}
            ></iframe>
          )}
        </div>
      </div>

      <!-- Article Content -->
      {toy.body && toy.body.trim().length > 0 && (
        <div class={`${styles.article} reveal`} data-delay="0.3">
          <Content />
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
