---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ToyCard from '@/components/ToyCard.astro';
import styles from '@/styles/ToysList.module.css';

type ToyEntry = CollectionEntry<'toys'>;

const allToys = await getCollection('toys');

const toys = allToys
  .filter((toy: ToyEntry) => !toy.data.draft)
  .sort((a: ToyEntry, b: ToyEntry) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Playground - Minkyu Han" description="코드로 만드는 인터랙티브 실험들.">
  <Header />

  <main class={styles.main}>
    <div class="container">
      <section class={styles.hero}>
        <p class="section-label reveal">Playground</p>
        <h1 class={`${styles.title} reveal`} data-delay="0.1">Toys & Experiments</h1>
        <p class={`${styles.desc} reveal`} data-delay="0.2">코드로 만드는 인터랙티브 실험들</p>
      </section>

      {toys.length > 0 ? (
        <div class={styles.grid}>
          {toys.map((toy: ToyEntry, i: number) => (
            <div class="reveal" data-delay={String(i * 0.1)}>
              <ToyCard
                title={toy.data.title}
                description={toy.data.description}
                slug={toy.slug}
                date={toy.data.date}
                techStack={toy.data.techStack}
                tags={toy.data.tags}
                featured={i === 0}
              />
            </div>
          ))}
        </div>
      ) : (
        <div class={styles.empty}>
          <p>Coming soon...</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
