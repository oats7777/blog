---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import styles from '@/styles/About.module.css';

const stats = [
  { number: '8+', label: 'Years Exp' },
  { number: '7+', label: 'Companies' },
  { number: '10+', label: 'Tech Stack' },
];

const skills = [
  {
    category: 'Frontend Core',
    items: ['TypeScript', 'React / Next.js', 'Vue3 / Nuxt', 'Zustand / TanStack Query'],
  },
  {
    category: 'Mobile & Backend',
    items: ['Capacitor', 'Supabase', 'Node.js'],
  },
  {
    category: 'DevOps & Testing',
    items: ['Vite / pnpm', 'Vitest / Storybook', 'CI/CD'],
  },
  {
    category: 'Specialty',
    items: ['Design System', 'Performance', 'WebGL / AWS IVS'],
  },
];

const experiences = [
  {
    period: '2026.01 - Present',
    title: 'CTO',
    company: '알고크라시',
    description: '서비스 전반의 기술 전략 수립, 시스템 아키텍처 설계, 팀 빌딩 및 기술 리더십',
    tags: ['Strategy', 'Architecture', 'Leadership'],
  },
  {
    period: '2025.09 - 2025.11',
    title: 'Frontend Developer',
    company: '벙커키즈 (Whif)',
    description: 'PWA → Capacitor 하이브리드 앱 전환, OTA 업데이트, 인앱결제 시스템 구축',
    tags: ['Capacitor', 'Supabase', 'RevenueCat'],
  },
  {
    period: '2025.03 - 2025.08',
    title: 'Frontend Developer',
    company: '혜움',
    description: 'Monocle 디자인 시스템 개발, 권한 관리 시스템 구축, 성능 최적화',
    tags: ['Vue3', 'Design System', 'Storybook'],
  },
  {
    period: '2024.04 - 2025.02',
    title: 'Frontend Developer',
    company: '플루언트',
    description: 'WebGL/AI 기반 인터랙션 플랫폼 Xavis 개발, 다국어 지원',
    tags: ['Next.js', 'WebGL', 'TanStack Query'],
  },
  {
    period: '2022.09 - 2024.03',
    title: 'Frontend Developer',
    company: '스푼라디오',
    description: 'Vue2 → Vue3 마이그레이션, AWS IVS 라이브 코어 엔진 교체, Web팀 리드',
    tags: ['Vue3', 'AWS IVS', 'Team Lead'],
  },
  {
    period: '2022.05 - 2022.08',
    title: 'Frontend Developer',
    company: '플라잉캣',
    description: '10분 특공대 앱 기능 개선, Code Push 시스템 구현',
    tags: ['React Native', 'Code Push'],
  },
  {
    period: '2018.12 - 2022.04',
    title: 'Full Stack Developer',
    company: '로앤컴퍼니',
    description: '빅케이스 판례검색 서비스 신규 개발, 로톡 비즈니스 2.0 풀스택 개발',
    tags: ['Next.js', 'Node.js', 'React'],
  },
];
---

<Layout
  title="About - Minkyu Han"
  description="8년차 프론트엔드 개발자 한민규의 소개와 경력, 기술 스택을 확인해보세요."
>
  <Header />

  <main class={styles.main}>
    <div class="container">
      <!-- Hero -->
      <section class={styles.hero}>
        <p class="section-label reveal">About Me</p>
        <h1 class={`${styles.name} reveal`} data-delay="0.1">한민규</h1>
        <p class={`${styles.role} reveal`} data-delay="0.2">Frontend Developer & Creative Engineer</p>
        <p class={`${styles.bio} reveal`} data-delay="0.3">
          사용자를 이해하고, 코드를 다듬고, 반복해 가치를 만드는 것이 저의 개발 철학입니다.
          React, Vue.js를 중심으로 디자인 시스템 구축, 성능 최적화, 팀 리드 경험을 통해
          지속 가능하고 확장 가능한 서비스를 만드는 데 집중하고 있습니다.
        </p>
        <div class={`${styles.socialLinks} reveal`} data-delay="0.4">
          <a href="https://github.com/oats7777" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/in/fe-minkyu" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:hanmin84200@gmail.com">Email</a>
        </div>
      </section>

      <!-- Stats -->
      <section class={styles.stats}>
        {stats.map((stat, i) => (
          <div class={`${styles.statItem} reveal`} data-delay={String(i * 0.1)}>
            <span class={styles.statNumber}>{stat.number}</span>
            <span class={styles.statLabel}>{stat.label}</span>
          </div>
        ))}
      </section>

      <!-- Experience -->
      <section class={styles.experience}>
        <p class="section-label reveal">Experience</p>
        <div class={styles.timeline}>
          {experiences.map((exp, i) => (
            <div class={`${styles.timelineItem} reveal`} data-delay={String(i * 0.08)}>
              <div class={styles.timelineDot}></div>
              <div class={styles.timelineContent}>
                <span class={styles.timePeriod}>{exp.period}</span>
                <h3 class={styles.timelineTitle}>{exp.title}</h3>
                <span class={styles.timelineCompany}>{exp.company}</span>
                <p class={styles.timelineDesc}>{exp.description}</p>
                <div class={styles.timelineTags}>
                  {exp.tags.map((tag: string) => (
                    <span class={styles.timelineTag}>{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Skills -->
      <section class={styles.skills}>
        <p class="section-label reveal">Skills & Tools</p>
        <div class={styles.skillsGrid}>
          {skills.map((group, i) => (
            <div class={`${styles.skillCard} reveal`} data-delay={String(i * 0.1)}>
              <h3 class={styles.skillCategory}>{group.category}</h3>
              <ul class={styles.skillList}>
                {group.items.map((item: string) => (
                  <li class={styles.skillItem}>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Education -->
      <section class={`${styles.education} reveal`}>
        <p class="section-label">Education</p>
        <div class={styles.eduItem}>
          <span class={styles.eduPeriod}>2016.03 - 2019.01</span>
          <h3 class={styles.eduTitle}>컴퓨터네트워크과</h3>
          <span class={styles.eduSchool}>서울전자고등학교</span>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Layout>
